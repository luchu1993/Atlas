<entity name="StressAvatar">

  <properties>
    <!-- hp drives Phase C2 end-to-end validation: a server-side OnTick
         mutator flips the value, every in-AoI client observes OnHpChanged
         through the reliable delta channel (0xF003). The `reliable` flag
         also sets up the C3 drop-window test for retransmit behaviour. -->
    <property name="hp" type="int32" scope="all_clients" reliable="true" />
  </properties>

  <cell_methods>
    <method name="Echo" exposed="own_client">
      <arg name="seq"        type="uint32" />
      <arg name="clientTsNs" type="uint64" />
    </method>
    <method name="ReportPos" exposed="all_clients">
      <arg name="pos" type="vector3" />
      <arg name="dir" type="vector3" />
    </method>
  </cell_methods>

  <client_methods>
    <method name="EchoReply">
      <arg name="seq"        type="uint32" />
      <arg name="serverTsNs" type="uint64" />
      <arg name="clientTsNs" type="uint64" />
    </method>
  </client_methods>

</entity>
