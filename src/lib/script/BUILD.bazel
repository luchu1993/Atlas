# src/lib/script/BUILD.bazel
#
# atlas_script — language-agnostic scripting abstraction

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "atlas_script",
    srcs = [
        "script_events.cc",
        "script_value.cc",
    ],
    hdrs = [
        "script_engine.h",
        "script_events.h",
        "script_object.h",
        "script_value.h",
    ],
    strip_include_prefix = "/src/lib",
    deps = [
        "//src/lib/foundation:atlas_foundation",
    ],
)
