{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_DEFAULT_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (no tests)",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ATLAS_ENABLE_PROFILER": "OFF",
        "ATLAS_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "profile",
      "displayName": "Profile (RelWithDebInfo + Tracy + viewer, no tests)",
      "binaryDir": "${sourceDir}/build/profile",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ATLAS_ENABLE_PROFILER": "ON",
        "ATLAS_BUILD_TRACY_VIEWER": "ON",
        "ATLAS_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "hybrid",
      "displayName": "RelWithDebInfo",
      "binaryDir": "${sourceDir}/build/hybrid",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "vs",
      "displayName": "Visual Studio solution (Debug, with tests)",
      "binaryDir": "${sourceDir}/build/vs",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "asan",
      "displayName": "AddressSanitizer (Linux)",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_C_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "asan-msvc",
      "displayName": "AddressSanitizer (MSVC)",
      "binaryDir": "${sourceDir}/build/asan-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "/EHsc /fsanitize=address",
        "CMAKE_C_FLAGS": "/fsanitize=address",
        "ATLAS_HEAP_ALLOCATOR": "std"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "tsan",
      "displayName": "ThreadSanitizer (Linux)",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread",
        "CMAKE_C_FLAGS": "-fsanitize=thread",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ubsan",
      "displayName": "UndefinedBehaviorSanitizer (Linux)",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=undefined",
        "CMAKE_C_FLAGS": "-fsanitize=undefined",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=undefined"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "net-client-android-arm64",
      "displayName": "atlas_net_client (Android arm64 / IL2CPP)",
      "binaryDir": "${sourceDir}/build/net-client-android-arm64",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-24",
        "ATLAS_BUILD_NET_CLIENT": "ON",
        "ATLAS_BUILD_TESTS": "OFF",
        "ATLAS_BUILD_CSHARP": "OFF",
        "ATLAS_ENABLE_PROFILER": "OFF",
        "ATLAS_HEAP_ALLOCATOR": "std"
      }
    },
    {
      "name": "net-client-ios-arm64",
      "displayName": "atlas_net_client (iOS arm64 static, macOS host required)",
      "binaryDir": "${sourceDir}/build/net-client-ios-arm64",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "16.3",
        "ATLAS_BUILD_NET_CLIENT": "ON",
        "ATLAS_BUILD_TESTS": "OFF",
        "ATLAS_BUILD_CSHARP": "OFF",
        "ATLAS_ENABLE_PROFILER": "OFF",
        "ATLAS_HEAP_ALLOCATOR": "std"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "net-client-macos-arm64",
      "displayName": "atlas_net_client (macOS arm64 .bundle)",
      "binaryDir": "${sourceDir}/build/net-client-macos-arm64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "ATLAS_BUILD_NET_CLIENT": "ON",
        "ATLAS_BUILD_TESTS": "OFF",
        "ATLAS_BUILD_CSHARP": "OFF",
        "ATLAS_ENABLE_PROFILER": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "net-client-linux-x64",
      "displayName": "atlas_net_client (Linux x64)",
      "binaryDir": "${sourceDir}/build/net-client-linux-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ATLAS_BUILD_NET_CLIENT": "ON",
        "ATLAS_BUILD_TESTS": "OFF",
        "ATLAS_BUILD_CSHARP": "OFF",
        "ATLAS_ENABLE_PROFILER": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "profile",
      "configurePreset": "profile"
    },
    {
      "name": "hybrid",
      "configurePreset": "hybrid"
    },
    {
      "name": "vs",
      "configurePreset": "vs",
      "configuration": "Debug"
    },
    {
      "name": "net-client-android-arm64",
      "configurePreset": "net-client-android-arm64",
      "targets": [
        "atlas_net_client"
      ]
    },
    {
      "name": "net-client-ios-arm64",
      "configurePreset": "net-client-ios-arm64",
      "targets": [
        "atlas_net_client_static"
      ],
      "configuration": "Release"
    },
    {
      "name": "net-client-macos-arm64",
      "configurePreset": "net-client-macos-arm64",
      "targets": [
        "atlas_net_client"
      ]
    },
    {
      "name": "net-client-linux-x64",
      "configurePreset": "net-client-linux-x64",
      "targets": [
        "atlas_net_client"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "vs",
      "configurePreset": "vs",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
