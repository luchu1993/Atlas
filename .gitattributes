# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.cpp        text eol=lf
*.hpp        text eol=lf
*.h          text eol=lf
*.c          text eol=lf
*.cmake      text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.in         text eol=lf

# Binary files — never convert
*.png        binary
*.jpg        binary
*.ico        binary
*.exe        binary
*.dll        binary
*.so         binary
*.a          binary
*.lib        binary
*.pdb        binary
