cc_test(
    name = "test_login_flow",
    srcs = ["test_login_flow.cpp"],
    deps = GTEST + [
        "//src/server/baseapp:atlas_baseapp_lib",
        "//src/server/baseappmgr:atlas_baseappmgr_lib",
        "//src/server/dbapp:atlas_dbapp_lib",
