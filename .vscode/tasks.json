{
  "version": "2.0.0",
  "tasks": [
    // ── Build All ─────────────────────────────────────────────────────
    {
      "label": "CMake: Build All",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$msCompile"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "CMake: Build All (Release)",
      "type": "shell",
      "command": "cmake --build build/release --config Release",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },

    // ── Test ──────────────────────────────────────────────────────────
    {
      "label": "CMake: Test All",
      "type": "shell",
      "command": "ctest --test-dir build/debug --build-config Debug --output-on-failure",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Test Single",
      "type": "shell",
      "command": "ctest --test-dir build/debug --build-config Debug -R ${input:testTarget} --output-on-failure",
      "group": "test",
      "problemMatcher": ["$msCompile"]
    },

    // ── Server Processes ──────────────────────────────────────────────
    {
      "label": "CMake: Build machined",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target machined",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build EchoApp",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_echoapp",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build LoginApp",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_loginapp",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build BaseApp",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_baseapp",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build BaseAppMgr",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_baseappmgr",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build DBApp",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_dbapp",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake: Build Client",
      "type": "shell",
      "command": "cmake --build build/debug --config Debug --target atlas_client",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },

    // ── Tooling ───────────────────────────────────────────────────────
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake --preset debug",
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (Release)",
      "type": "shell",
      "command": "cmake --preset release",
      "problemMatcher": []
    },
    {
      "label": "clang-format: Check Changed Files",
      "type": "shell",
      "command": "git diff --name-only --diff-filter=AM HEAD | grep -E '\\.(cc|h|cpp|hpp)$' | xargs -r \"C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/Llvm/x64/bin/clang-format.exe\" --dry-run --Werror",
      "problemMatcher": []
    },
    {
      "label": "clang-format: Fix Changed Files",
      "type": "shell",
      "command": "git diff --name-only --diff-filter=AM HEAD | grep -E '\\.(cc|h|cpp|hpp)$' | xargs -r \"C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/Llvm/x64/bin/clang-format.exe\" -i",
      "problemMatcher": []
    }
  ],
