{
  "version": "0.2.0",
  "configurations": [
    // ── Server Processes ──────────────────────────────────────────────
    // Start order: machined -> DBAppMgr -> BaseAppMgr -> CellAppMgr
    //              -> DBApp -> BaseApp -> CellApp -> LoginApp
    {
      "name": "machined",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/server/machined/Debug/machined.exe",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build machined"
    },
    {
      "name": "LoginApp",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/server/loginapp/Debug/atlas_loginapp.exe",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build LoginApp"
    },
    {
      "name": "BaseApp",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/server/baseapp/Debug/atlas_baseapp.exe",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build BaseApp"
    },
    {
      "name": "BaseAppMgr",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/server/baseappmgr/Debug/atlas_baseappmgr.exe",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build BaseAppMgr"
    },
    {
      "name": "DBApp",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/server/dbapp/Debug/atlas_dbapp.exe",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build DBApp"
    },
    {
      "name": "Client",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/client/Debug/atlas_client.exe",
      "args": [
        "--username", "testuser",
        "--password", "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "CMake: Build Client"
    },

    // ── Attach to running process ─────────────────────────────────────
    {
      "name": "Attach to Process",
      "type": "cppvsdbg",
      "request": "attach"
    }
  ]
}
