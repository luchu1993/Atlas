# .bazelrc — Atlas Engine Bazel configuration
# Replaces cmake/AtlasCompilerOptions.cmake

# ── Common flags ──────────────────────────────────────────────────────────────
# Apply OS-specific config blocks automatically (windows / linux)
build --enable_platform_specific_config

# C++20 is set per-platform below (MSVC uses /std:c++20, GCC/Clang uses -std=c++20)

# Architecture
build --copt=-DATLAS_ARCH_X64=1

# ── Windows / MSVC ───────────────────────────────────────────────────────────
build:windows --cxxopt=/std:c++20
build:windows --host_cxxopt=/std:c++20
build:windows --cxxopt=/W4
build:windows --cxxopt=/WX
build:windows --cxxopt=/permissive-
build:windows --cxxopt=/utf-8
build:windows --cxxopt=/Zc:__cplusplus
build:windows --cxxopt=/Zc:preprocessor
# Suppress: unreferenced formal parameter (C4100) — common in virtual overrides
build:windows --cxxopt=/wd4100
build:windows --copt=/DATLAS_PLATFORM_WINDOWS=1

# Bazel auto-detects MSVC. If needed, set BAZEL_VC env var before invoking:
#   set BAZEL_VC=C:\Program Files\Microsoft Visual Studio\2022\Community\VC

# ── Linux / GCC or Clang ─────────────────────────────────────────────────────
build:linux --cxxopt=-std=c++20
build:linux --host_cxxopt=-std=c++20
build:linux --cxxopt=-Wall
build:linux --cxxopt=-Wextra
build:linux --cxxopt=-Wpedantic
build:linux --cxxopt=-Werror
build:linux --cxxopt=-Wno-unused-parameter
# GCC 13 false positive: atomic load on ref-counted objects inlined through
# lambdas triggers bogus "writing N bytes into a region of size 0" warnings.
build:linux --cxxopt=-Wno-stringop-overflow
build:linux --cxxopt=-Wconversion
build:linux --cxxopt=-Wnon-virtual-dtor
# Position-independent code (required for atlas_engine shared library)
build:linux --cxxopt=-fPIC
build:linux --copt=-DATLAS_PLATFORM_LINUX=1

# ── Build configurations ──────────────────────────────────────────────────────
# Debug: full symbols, assertions, debug defines
build:debug --compilation_mode=dbg
build:debug --copt=-DATLAS_DEBUG=1

# Release: fully optimized, NDEBUG
build:release --compilation_mode=opt
build:release --copt=-DNDEBUG

# Hybrid (RelWithDebInfo equivalent): optimized + debug symbols
build:hybrid --compilation_mode=opt
build:hybrid --copt=-g
build:hybrid --strip=never

# ── Sanitizers ───────────────────────────────────────────────────────────────
# ASan (Linux / GCC / Clang)
build:asan --copt=-fsanitize=address
build:asan --linkopt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer

# ASan (Windows / MSVC) — MSVC auto-links the ASan runtime
build:asan-msvc --copt=/fsanitize=address

# TSan (Linux only — MSVC does not support ThreadSanitizer)
build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread

# UBSan (Linux only — MSVC does not support UndefinedBehaviorSanitizer)
build:ubsan --copt=-fsanitize=undefined
build:ubsan --linkopt=-fsanitize=undefined

# ── Optional features (defaults) ─────────────────────────────────────────────
# MySQL backend disabled by default (enable with --define=ATLAS_DB_MYSQL=1)
build --define=ATLAS_DB_MYSQL=0

# ── Test output ───────────────────────────────────────────────────────────────
test --test_output=errors

# ── .NET / NuGet environment (for genrule-based C# builds) ───────────────────
# NuGet needs USERPROFILE/APPDATA/LOCALAPPDATA to find its package cache.
# Bazel strips these from genrule actions by default.
build --action_env=USERPROFILE
build --action_env=APPDATA
build --action_env=LOCALAPPDATA

# ── Parallel build tuning ─────────────────────────────────────────────────────
build --jobs=auto
build --local_resources=memory=HOST_RAM*.75
build --local_resources=cpu=HOST_CPUS*.75

# ── Remote cache (Phase 7 — fill in BAZEL_REMOTE_CACHE env var in CI) ────────
# build:ci --remote_cache=${BAZEL_REMOTE_CACHE}
# build:ci --remote_upload_local_results=true
